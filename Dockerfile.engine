FROM node:22-alpine

WORKDIR /usr/src/app

RUN apk add --no-cache curl

COPY package*.json ./
RUN npm ci --omit=dev

COPY . .

ENV NODE_ENV=production
ENV ENGINE_MODE=shadow
ENV ENGINE_PORT=3201
ENV ENGINE_HOST=0.0.0.0

EXPOSE 3201

# Processo da engine — separado da UI (Dockerfile → sirv :3200)
CMD ["node", "scripts/engine-serve.js"]
