PORT=3200
HOST=0.0.0.0

# Dashboard público faz proxy somente para a engine interna.
ENGINE_INTERNAL_URL=http://data-robot-engine:3201
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# ── Polymarket CLOB (trading real) ─────────────────────────────
POLYMARKET_PRIVATE_KEY=0xSUA_CHAVE_PRIVADA_AQUI

# Credenciais L2 — use: npm run derive-key:write
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# 0=EOA, 1=POLY_PROXY (email/Magic), 2=GNOSIS_SAFE, 3=POLY_1271 (deposit wallet)
POLYMARKET_SIGNATURE_TYPE=1

# Endereço do perfil (proxyWallet) — polymarket.com/settings
POLYMARKET_FUNDER_ADDRESS=

POLYMARKET_DERIVE_NONCE_MAX=50

# ── Engine/control plane ───────────────────────────────────────
ENGINE_MODE=shadow
ENGINE_LIVE_ENABLED=0
ENGINE_HOST=0.0.0.0
ENGINE_PORT=3201
ENGINE_OPS_TOKEN=troque-por-token-longo-e-aleatorio
ENGINE_CHECKPOINT_MS=30000
ENGINE_STATE_DIR=runs
ENGINE_CANARY_MODE=0
ENGINE_CANARY_MAX_BUDGET=3
ENGINE_CONTROL_WINDOW_MS=86400000
ENGINE_STRATEGY_ID=fixture-price-cross
ENGINE_STRATEGY_INSTANCE_ID=fixture-price-cross:primary
STRATEGY_CATALOG_PATH=config/strategy-catalog.json
# fixture = smoke/soak sem rede; btc5m = Gamma + RTDS + CLOB; manual = sem runner
ENGINE_SNAPSHOT_SOURCE=fixture
# Watchdog/fallback; mensagens RTDS/CLOB disparam ingest imediatamente.
ENGINE_SOURCE_INTERVAL_MS=100
ENGINE_MARKET_SYNC_MS=15000
ENGINE_SOURCE_RETRY_MS=2000
